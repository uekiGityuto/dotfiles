{
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**/src/**)",
      "Write(**/src/**)",
      "Read(**/tmp/claude/**)",
      "Edit(**/tmp/claude/**)",
      "Write(**/tmp/claude/**)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(gemini *)",
      "Bash(git *status*)",
      "Bash(git *diff*)",
      "Bash(git *log*)",
      "Bash(git *lf-files*)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr view *)",
      "Bash(gh issue view *)",
      "Bash(gh search issues *)",
      "Bash(python3 ~/.agents/skills/skill-creator/scripts/init_skill.py *)",
      "Bash(python3 ~/.agents/skills/skill-creator/scripts/quick_validate.py *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:claude.ai)",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__pencil",
      "Skill(browser-use)",
      "Skill(create-pr-with-screenshots)",
      "Skill(find-skills)",
      "Skill(skill-creator)",
      "Skill(takt)",
      "Skill(codex)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(*.pem)",
      "Read(**/credentials/**)",
      "Read(~/credentials/**)",
      "Bash(*publish*)",
      "Bash(terraform *apply*)",
      "Bash(kubectl *apply*)",
      "Bash(*deploy*)"
    ],
    "ask": ["Bash(git *config *)"],
    "additionalDirectories": ["~/Downloads/work", "/tmp/claude"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-chained-commands.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-multiline-bash.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-cd.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-approve-tmp-write.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-approve-tmp-write.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Hero.aiff || true"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff || true"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Hero.aiff || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "language": "japanese",
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowLocalBinding": true
    },
    "env": {
      "TMPPREFIX": "/private/tmp/claude-501/zsh"
    },
    "excludedCommands": ["git *", "gh *"]
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  }
}
