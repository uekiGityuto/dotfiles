{
  "permissions": {
    "allow": [
      "Edit(**/src/**)",
      "Write(**/src/**)",
      "Read(**)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(rm *)",
      "Bash(gemini *)",
      "Bash(git *status*)",
      "Bash(git *diff*)",
      "Bash(git *log*)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr view *)",
      "Bash(gh search issues *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:claude.ai)",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(sudo *)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Bash(git *reset *)",
      "Bash(git *checkout *)",
      "Bash(* publish *)"
    ],
    "ask": [
      "Bash(git *rebase *)",
      "Bash(git *config *)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/pg/my/dotfiles/assets/sounds/zelda.mp3 || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}