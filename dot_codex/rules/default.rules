# Default rules apply to every Codex session for this user.
# Keep this file limited to generic, read-only commands that are safe across repositories.

# Local process and container status
prefix_rule(pattern=["ps", "aux"], decision="allow")
prefix_rule(pattern=["docker", "context", "ls"], decision="allow")
prefix_rule(pattern=["docker", "info", "--format"], decision="allow")
prefix_rule(pattern=["docker", "ps", "--format"], decision="allow")
prefix_rule(pattern=["colima", "status"], decision="allow")

# Local Codex rule setup
prefix_rule(pattern=["mkdir", "-p", ".codex/rules"], decision="allow")
