{
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**/src/**)",
      "Write(**/src/**)",
      "Read(~/.claude/tmp/pr-body.md)",
      "Edit(~/.claude/tmp/pr-body.md)",
      "Write(~/.claude/tmp/pr-body.md)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(gemini *)",
      "Bash(git *status*)",
      "Bash(git *diff*)",
      "Bash(git *log*)",
      "Bash(git *lf-files*)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr view *)",
      "Bash(gh search issues *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:claude.ai)",
      "WebFetch(domain:docs.anthropic.com)",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(sudo *)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(*.pem)",
      "Read(**/credentials/**)",
      "Read(~/credentials/**)",
      "Bash(*publish*)",
      "Bash(terraform *apply*)",
      "Bash(kubectl *apply*)",
      "Bash(*deploy*)"
    ],
    "ask": ["Bash(git *config *)"],
    "additionalDirectories": ["/Users/ueki/Downloads/work", "~/.claude/tmp"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-chained-commands.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/enforce-body-file.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Hero.aiff || true"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff || true"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Hero.aiff || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "language": "japanese",
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowLocalBinding": true
    },
    "env": {
      "TMPPREFIX": "/private/tmp/claude-501/zsh"
    }
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
