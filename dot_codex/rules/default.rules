prefix_rule(pattern=["gh", "auth"], decision="allow")
prefix_rule(pattern=["gh", "pr"], decision="allow")
prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["git", "add", "-u"], decision="allow")
prefix_rule(pattern=["pnpm", "vitest", "--project", "storybook"], decision="allow")
prefix_rule(pattern=["pnpm", "test:vrt"], decision="allow")
prefix_rule(pattern=["pnpm", "test:vrt:update"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "CI=true pnpm install --no-frozen-lockfile"], decision="allow")
prefix_rule(pattern=["pnpm", "test:vrt:file:update"], decision="allow")
prefix_rule(pattern=["pnpm", "test:vrt:file"], decision="allow")
prefix_rule(pattern=["curl", "-fsSL"], decision="allow")
